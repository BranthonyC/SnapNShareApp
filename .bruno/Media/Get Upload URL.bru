meta {
  name: Get Upload URL
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/events/{{eventId}}/upload-url
  body: json
  auth: none
}

headers {
  Authorization: Bearer {{guestToken}}
}

body:json {
  {
    "fileType": "image/jpeg",
    "fileSize": 1048576,
    "uploaderName": "Test Guest"
  }
}
