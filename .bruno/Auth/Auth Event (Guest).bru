meta {
  name: Auth Event (Guest)
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/events/{{eventId}}/auth
  body: json
  auth: none
}

body:json {
  {
    "password": "test1234"
  }
}

script:post-response {
  if (res.status === 200) {
    const body = res.getBody();
    bru.setVar("guestToken", body.token);
  }
}
